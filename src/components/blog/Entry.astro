---
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { title, url, author, pubDate, description, image, titleInside = false } = Astro.props;

// Ensure we have a fallback if WordPress doesn't have a featured image set
const fallbackImage = "https://mintaka.co/opengraph/social-og.jpg";
---

<a href={translatePath(url)} title={title} class="group">
    <article class="relative flex h-full flex-1 flex-col overflow-hidden rounded-lg">
        <div
            class:list={[
                "article-overlay relative block w-full overflow-hidden lg:col-span-2",
                /* We added 'aspect-[3/2]' here for a taller, bigger look */
                titleInside ? "article-gradient-overlay-bottom aspect-[3/2]" : "article-gradient-overlay aspect-[3/2]",
            ]}>
            <Image 
                /* 1. Changed aspect ratio to 3/2 (Standard photography size)
                   2. Added 'transition-transform' for a smooth hover effect
                   3. Replaced h-full with h-auto to respect the new ratio
                */
                class="relative aspect-[3/2] h-auto w-full bg-center object-cover transition-transform duration-500 group-hover:scale-105" 
                src={image || fallbackImage} 
                alt={title} 
                width={1200}  /* Increased to 1200 for better clarity */
                height={800}  /* Matches 3:2 ratio */
                format="webp" 
                quality="mid"
            />
        </div>
        <div
            class={`flex w-full flex-1 flex-col items-start justify-between ${
                titleInside ? "absolute bottom-0 text-white p-12" : "text-black pt-4 md:p-2 md:pt-6"
            }`}>
            <div class="w-full">
                <div>
                    /* Slightly increased the title size to match the bigger image */
                    <p class="font-mono text-xl font-bold uppercase tracking-wide lg:text-2xl">
                        {title}
                    </p>
                </div>
                <p class={`mt-2 line-clamp-3 text-base ${titleInside ? "text-slate-200" : "text-slate-600"}`}>
                    {description}
                </p>
            </div>
            <footer>
                <div class="mt-6 inline-flex items-center space-x-1">
                    <p class={`text-xs font-medium ${titleInside ? "text-slate-200" : "text-slate-900"}`}>
                        {/* WordPress author mapping */}
                        {typeof author === 'string' ? author : author?.name || "Admin"}
                    </p>
                    <span aria-hidden="true">&middot;</span>
                    <div class={`flex text-xs ${titleInside ? "text-slate-300" : "text-slate-500"}`}>
                        <time datetime={pubDate}>{pubDate}</time>
                    </div>
                </div>
            </footer>
        </div>
    </article>
</a>

<style>
    /* Styles remain exactly the same as your original */
    .article-overlay,
    .article-overlay img {
        border-radius: inherit;
    }
    .article-overlay.article-gradient-overlay {
        background: linear-gradient(0deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0) 100%);
    }
    .article-overlay.article-gradient-overlay-bottom {
        background: linear-gradient(0deg, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 1) 5%, rgba(0, 0, 0, 0) 50%);
    }
    .article-overlay:before {
        content: "";
        border-radius: inherit;
        filter: url(#article-noise-filter);
        opacity: 0.5;
        z-index: 10;
        @apply absolute bottom-0 left-0 right-0 top-0 rounded-lg;
    }
</style>