---
// src/components/CookieConsent.astro
---

<div id="consent-banner" 
     style="display: none; z-index: 9999;" 
     class="fixed bottom-4 right-4 max-w-sm bg-white border border-gray-200 shadow-2xl rounded-lg p-6">
  
  <h3 class="text-lg font-bold mb-2 text-gray-900">Privacy Settings</h3>
  
  <div class="space-y-3 mb-6">
    <label class="flex items-center gap-3 cursor-pointer">
      <input type="checkbox" id="check-google" class="w-4 h-4" checked>
      <span class="text-sm text-gray-700">Google Analytics</span>
    </label>
    <label class="flex items-center gap-3 cursor-pointer">
      <input type="checkbox" id="check-meta" class="w-4 h-4" checked>
      <span class="text-sm text-gray-700">Meta Pixel</span>
    </label>
  </div>

  <div class="flex flex-col gap-2">
    <button onclick="handleConsentClick(false)" class="w-full bg-black text-white py-2 rounded font-semibold">
      Save Preferences
    </button>
    <button onclick="handleConsentClick(true)" class="w-full bg-gray-100 text-gray-800 py-2 rounded font-semibold text-sm">
      Accept All
    </button>
  </div>
</div>

<script is:inline>
  // 1. Define the handler globally so the buttons can always see it
  window.handleConsentClick = function(acceptAll) {
    const banner = document.getElementById('consent-banner');
    const googleChecked = document.getElementById('check-google').checked;
    const metaChecked = document.getElementById('check-meta').checked;

    const prefs = acceptAll 
      ? { google: true, meta: true } 
      : { google: googleChecked, meta: metaChecked };

    // Hide immediately
    if (banner) banner.style.display = 'none';
    
    // Save to storage
    localStorage.setItem('site-consent', JSON.stringify(prefs));
    
    // Reload to fire tracking scripts
    window.location.reload();
  };

  // 2. Check visibility on load
  function checkConsentVisibility() {
    const banner = document.getElementById('consent-banner');
    if (banner && !localStorage.getItem('site-consent')) {
      banner.style.display = 'block';
    }
  }

  checkConsentVisibility();
  document.addEventListener('astro:after-swap', checkConsentVisibility);
</script>