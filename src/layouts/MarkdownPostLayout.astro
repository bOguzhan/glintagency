---
import Cta from "@/components/blog/Cta.astro";
import type { AstroSeoProps } from "@astrolib/seo";
import Comments from "@components/blog/Comments.astro";
import Title from "@components/global/Title.astro";
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";
import BaseLayout from "./BaseLayout.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

type Props = {
    frontmatter: any;
    body?: string; // Changed to optional to prevent errors if undefined
    seo?: AstroSeoProps;
};

const { frontmatter, body = "", seo } = Astro.props;

const shareImage = "/images/meta/mintaka_share.gif";
const postAlt = frontmatter.image?.alt || frontmatter.title;

function getArticleReadingTime(content: string): number {
    if (!content) return 0;
    const wordsPerMinute = 183;
    const numberOfWords = content.split(/\s/g).length;
    const minutes = numberOfWords / wordsPerMinute;
    return Math.ceil(minutes);
}

const readingTime = getArticleReadingTime(body);
---

<BaseLayout seo={seo}>
    <link 
      rel="stylesheet" 
      href="https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.css" 
    />

    <section>
        <div class="mx-auto max-w-7xl px-8 py-12 md:px-12 lg:px-32 lg:py-32">
            <div class="flex flex-col gap-6 pt-20">
                <Title
                    title={frontmatter.title}
                    subtitle={`Written by: <a href="${frontmatter.author.link}" rel="author">${frontmatter.author.name}</a> on ${frontmatter.pubDate
                        .toString()
                        .slice(0, 10)}`}
                />

                <p class="max-w-2xl text-base text-slate-500">
                    <em>{frontmatter.description}</em>
                </p>
            </div>

            <div class="mt-12 w-full justify-center">
                <div class="flex justify-between px-2 pt-4 font-mono text-sm">
                    <div class="flex flex-wrap gap-1">
                        {frontmatter?.tags?.length > 0 && <span class="py-3 text-slate-400">TAGS:</span>}
                        <ul class="flex flex-wrap justify-center">
                            {
                                frontmatter?.tags?.map((tag: string) => (
                                    <li class="inline-flex items-center rounded-full px-1 py-3 font-medium uppercase tracking-widest text-slate-600 hover:text-black">
                                        <a href={`/tags/${tag}`}>{tag}</a>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <span class="py-3 text-slate-400">~{readingTime} MIN</span>
                </div>

                <div id="post-content" class="prose-styles mt-12">
                    <slot />
                </div>
            </div>
            <Comments />
        </div>
    </section>
</BaseLayout>

<script>
  import PhotoSwipeLightbox from 'https://unpkg.com/photoswipe@5.4.3/dist/photoswipe-lightbox.esm.js';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#post-content',
    children: 'img', // Automatically captures all images in the post
    pswpModule: () => import('https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.esm.js'),
  });

  // Dynamically calculate image dimensions for the popup
  lightbox.addFilter('itemData', (itemData) => {
    const img = itemData.element as HTMLImageElement;
    return {
      src: img.src,
      w: img.naturalWidth || 1200,
      h: img.naturalHeight || 800,
      alt: img.alt
    };
  });

  lightbox.init();
</script>

<style is:global>
  /* 3. Global fixes for WordPress images */
  #post-content img {
    cursor: zoom-in;
    background: transparent !important;
    height: auto !important;
    /* Removed aspect-ratio to prevent the "dark box" issue */
  }

  /* Clear WP figure backgrounds */
  #post-content figure {
    background: transparent !important;
    margin-bottom: 1.5rem;
  }

  /* Ensure links around images don't interfere with the click */
  #post-content a:has(img) {
    pointer-events: none;
    cursor: default;
  }
  
  #post-content img {
    pointer-events: auto;
  }
</style>