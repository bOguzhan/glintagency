---
import BlobCursorFollower from "@/components/global/BlobCursorFollower.astro";
import { AstroSeo, type AstroSeoProps } from "@astrolib/seo";
import BaseHead from "@components/BaseHead.astro";
import BackgroundTexture from "@components/global/BackgroundTexture.astro";
import Footer from "@components/global/Footer.astro";
import Navigation from "@components/global/Navigation.astro";
import { getLangFromUrl } from "../i18n/utils";

const { pathname } = Astro.url;

type Props = {
    seo?: AstroSeoProps;
};

const { seo: seoProp } = Astro.props;

const lang = getLangFromUrl(Astro.url);

const shareImage = new URL("/images/meta/mintaka_share.gif", Astro.site).toString();

const defaultSeo: AstroSeoProps = {
    title: "Design Agency Leading in Performant Web Design Solutions - Glint Agency",
    description: "Glint Agency excels in creating fast, user-friendly websites with a focus on aesthetic design and SEO optimization.",
    canonical: "https://glintagency.com",
    openGraph: {
        url: "https://glintagency.com",
        title: "Design Agency Leading in Performant Web Design Solutions - Glint Agency",
        description: "Glint Agency excels in creating fast, user-friendly websites.",
        images: [{ url: shareImage, width: 1200, height: 630, alt: "Social open graph", type: "image/gif" }],
        site_name: "Glint",
    },
};

const seo = { ...defaultSeo, ...seoProp };

function cursorFollowerActive() {
    const paths = ["", "/", "/it/", "/it"];
    return paths.includes(pathname);
}
---

<html lang={lang}>
    <head>
        <BaseHead />
        <AstroSeo {...seo} />
    </head>
    <body class="bg-slate-50">
        <div id="preloader" class="fixed inset-0 z-[100] overflow-hidden bg-transparent pointer-events-none">
  
            <div id="preloader-bg" class="absolute inset-0 bg-white z-0 pointer-events-auto"></div>

            <div id="preloader-top" class="absolute top-0 left-0 w-full h-1/2 bg-[#800020] z-10 pointer-events-auto opacity-0"></div>
            <div id="preloader-bottom" class="absolute bottom-0 left-0 w-full h-1/2 bg-[#800020] z-10 pointer-events-auto opacity-0"></div>

<div id="wine-wrapper" class="absolute bottom-0 left-0 w-full bg-[#800020] z-20" style="height: 0%;">
    <svg class="absolute left-0 w-[400%] h-[180px] z-30 pointer-events-none" id="wine-curve" viewBox="0 24 150 28" preserveAspectRatio="none" style="top: -170px;">
        <defs>
            <path id="tight-wave" d="M-160 44c30 0 30-25 60-25s 30 25 60 25 30-25 60-25 30 25 60 25 v44h-240z" />
        </defs>
        <g class="parallax-water">
            <use xlink:href="#tight-wave" x="48" y="0" fill="rgba(128, 0, 32, 0.3)" />
            <use xlink:href="#tight-wave" x="48" y="2" fill="rgba(128, 0, 32, 0.5)" />
            <use xlink:href="#tight-wave" x="48" y="4" fill="rgba(128, 0, 32, 0.8)" />
            <use xlink:href="#tight-wave" x="48" y="6" fill="#800020" />
        </g>
    </svg>
</div>

            <div id="loader-content" class="fixed bottom-0 left-0 z-40 p-6 md:p-10 flex items-baseline pointer-events-none">
    <div class="flex items-baseline text-white mix-blend-difference">
        <span id="loader-percent" class="text-[15vw] md:text-[10vw] font-black leading-[0.8] tracking-tighter">0</span>
        <span class="text-[5vw] md:text-[3vw] font-light ml-2">%</span>
    </div>
</div>
        </div>

        <BackgroundTexture />
        <Navigation />
        {cursorFollowerActive() && <BlobCursorFollower />}
        <slot />
        <Footer />
        
        <div id="sparkle-container" style="position: fixed; top: 0; left: 0; pointer-events: none; z-index: 9999;"></div>

        <script>
            import { gsap } from "gsap";

            function initLoader() {
                const percentText = document.querySelector("#loader-percent");
                const wineWrapper = document.querySelector("#wine-wrapper");
                const preloader = document.querySelector("#preloader");
                const preloaderBg = document.querySelector("#preloader-bg");
                const preloaderTop = document.querySelector("#preloader-top");
                const preloaderBottom = document.querySelector("#preloader-bottom");
                const loaderContent = document.querySelector("#loader-content");
                
                if (!percentText || !wineWrapper || !preloaderTop || !preloaderBottom) return;

 // 1. SEA-LIKE WAVE MOTION
const layers = document.querySelectorAll(".parallax-water use");
layers.forEach((layer, i) => {
    // We move each layer at a different speed and distance
    gsap.to(layer, {
        x: i % 2 === 0 ? -200 : -150, // Move left
        duration: 3 + (i * 1),        // Different speeds for parallax effect
        repeat: -1,                   // Loop forever
        ease: "none"                  // Constant speed for natural flow
    });

    // Add a slight vertical "bobbing" to the waves
    gsap.to(layer, {
        y: i % 2 === 0 ? 5 : -5,
        duration: 2 + (i * 0.5),
        repeat: -1,
        yoyo: true,
        ease: "sine.inOut"
    });
});

                // 2. TIMELINE
                const tl = gsap.timeline();
                const counter = { val: 0 };

                tl.to(counter, {
                    val: 100,
                    duration: 1.8,
                    ease: "power2.inOut", 
                    onUpdate: () => {
                        percentText.innerText = Math.round(counter.val);
                    }
                }, 0);

                tl.to(wineWrapper, {
                    height: "100%",
                    duration: 1.8,
                    ease: "power2.inOut"
                }, 0);

                // 3. THE HAND-OFF
                tl.set([preloaderTop, preloaderBottom], { opacity: 1 });
                tl.set([preloaderBg, wineWrapper, loaderContent], { display: "none" });

                // 4. THE SPLIT
                tl.to(preloaderTop, {
                    yPercent: -100,
                    duration: 1.1,
                    ease: "expo.inOut"
                });

                tl.to(preloaderBottom, {
                    yPercent: 100,
                    duration: 1.1,
                    ease: "expo.inOut",
                    onComplete: () => {
                        preloader.style.display = "none";
                        if (typeof window.init === "function") window.init();
                    }
                }, "<"); 
            }

            // Sparkle logic
            const container = document.getElementById('sparkle-container');
            const colors = ["#800020", "#800020", "#800020", "#FFD700"]; 
            window.addEventListener("mousemove", (e) => {
                if(container) createSparkle(e.clientX, e.clientY);
            });

            function createSparkle(x, y) {
                const sparkle = document.createElement("div");
                const size = Math.random() * 8 + 8; 
                const color = colors[Math.floor(Math.random() * colors.length)];
                Object.assign(sparkle.style, {
                    position: "absolute",
                    left: `${x}px`,
                    top: `${y}px`,
                    width: `${size}px`,
                    height: `${size}px`,
                    backgroundColor: color,
                    clipPath: "polygon(50% 0%, 61% 39%, 100% 50%, 61% 61%, 50% 100%, 39% 61%, 0% 50%, 39% 39%)",
                    pointerEvents: "none",
                    zIndex: "9999"
                });
                container.appendChild(sparkle);
                gsap.to(sparkle, {
                    duration: 0.8,
                    x: (Math.random() - 0.5) * 100, 
                    y: (Math.random() - 0.5) * 100,
                    scale: 0,
                    opacity: 0,
                    ease: "power1.out",
                    onComplete: () => sparkle.remove()
                });
            }

            document.addEventListener("DOMContentLoaded", initLoader);
        </script>

        <script>
            import Lenis from 'lenis'
            import { gsap } from 'gsap'
            import { ScrollTrigger } from 'gsap/ScrollTrigger'
            const lenis = new Lenis({ duration: 1.2, smoothWheel: true })
            lenis.on('scroll', ScrollTrigger.update)
            gsap.ticker.add((time) => { lenis.raf(time * 1000) })
        </script>

        <style is:global>
            html.lenis, html.lenis body { height: auto; }
            .lenis.lenis-smooth { scroll-behavior: auto !important; }
        </style>
    </body>
</html>