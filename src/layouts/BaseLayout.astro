---
import BlobCursorFollower from "@/components/global/BlobCursorFollower.astro";
import { AstroSeo, type AstroSeoProps } from "@astrolib/seo";
import BaseHead from "@components/BaseHead.astro";
import BackgroundTexture from "@components/global/BackgroundTexture.astro";
import Footer from "@components/global/Footer.astro";
import Navigation from "@components/global/Navigation.astro";
import { getLangFromUrl } from "../i18n/utils";

const { pathname } = Astro.url;

type Props = {
    seo?: AstroSeoProps;
};

const { seo: seoProp } = Astro.props;

const lang = getLangFromUrl(Astro.url);

const shareImage = new URL("/images/meta/mintaka_share.gif", Astro.site).toString();

const defaultSeo: AstroSeoProps = {
    title: "Design Agency Leading in Performant Web Design Solutions - Glint Agency",
    description: "Glint Agency excels in creating fast, user-friendly websites with a focus on aesthetic design and SEO optimization.",
    canonical: "https://glintagency.com",
    openGraph: {
        url: "https://glintagency.com",
        title: "Design Agency Leading in Performant Web Design Solutions - Glint Agency",
        description: "Glint Agency excels in creating fast, user-friendly websites.",
        images: [{ url: shareImage, width: 1200, height: 630, alt: "Social open graph", type: "image/gif" }],
        site_name: "Glint",
    },
};

const seo = { ...defaultSeo, ...seoProp };

function cursorFollowerActive() {
    const paths = ["", "/", "/it/", "/it"];
    return paths.includes(pathname);
}
---

<html lang={lang}>
    <head>
        <BaseHead />
        <AstroSeo {...seo} />
    </head>
    <body class="bg-slate-50">
        <div id="preloader" class="fixed inset-0 z-[100] flex items-center justify-center overflow-hidden bg-transparent pointer-events-none">
  
            <div id="preloader-top" class="absolute top-0 left-0 w-full h-1/2 bg-[#800020] z-10 pointer-events-auto"></div>
            <div id="preloader-bottom" class="absolute bottom-0 left-0 w-full h-1/2 bg-[#800020] z-10 pointer-events-auto"></div>


            <div id="wine-wrapper" class="absolute bottom-0 left-0 w-full bg-[#800020] z-20 overflow-hidden" style="height: 0%;">
                <svg class="absolute left-0 w-[400%] h-[150px] z-30 pointer-events-none" id="wine-curve" viewBox="0 24 150 28" preserveAspectRatio="none" style="top: -148px;">
                    <defs>
                        <path id="choppy-wave" d="M-160 44c15 0 29-20 44-20s 29 20 44 20 29-20 44-20 29 20 44 20 v44h-176z" />
                    </defs>
                    <g class="parallax">
                        <use xlink:href="#choppy-wave" x="48" y="0" fill="rgba(128, 0, 32, 0.3)" />
                        <use xlink:href="#choppy-wave" x="48" y="3" fill="rgba(128, 0, 32, 0.5)" />
                        <use xlink:href="#choppy-wave" x="48" y="5" fill="rgba(128, 0, 32, 0.7)" />
                        <use xlink:href="#choppy-wave" x="48" y="7" fill="#800020" />
                    </g>
                </svg>
            </div>

            <div id="loader-content" class="absolute inset-0 z-40 flex items-center justify-center pointer-events-none">
                <div class="flex items-baseline text-white">
                    <span id="loader-percent" class="text-[18vw] font-black leading-none tracking-tighter">0</span>
                    <span class="text-[5vw] font-light ml-2">%</span>
                </div>
            </div>
        </div>

        <BackgroundTexture />
        <Navigation />
        {cursorFollowerActive() && <BlobCursorFollower />}
        <slot />
        <Footer />
        
        <div id="sparkle-container" style="position: fixed; top: 0; left: 0; pointer-events: none; z-index: 9999;"></div>

        <script>
            import { gsap } from "gsap";

            function initLoader() {
    const percentText = document.querySelector("#loader-percent");
    const wineWrapper = document.querySelector("#wine-wrapper");
    const wineCurve = document.querySelector("#wine-curve");
    const preloader = document.querySelector("#preloader");
    const preloaderTop = document.querySelector("#preloader-top");
    const preloaderBottom = document.querySelector("#preloader-bottom");
    const loaderContent = document.querySelector("#loader-content");
    
    if (!percentText || !wineWrapper || !preloaderTop || !preloaderBottom) return;

    // 1. CONSTANT WAVE CHOP
    gsap.to(".parallax use", {
        x: (i) => i % 2 === 0 ? -45 : 35,
        repeat: -1,
        duration: 0.8,
        ease: "sine.inOut",
        yoyo: true
    });

    // 2. THE 3-SECOND SMOOTH TIMELINE
    const tl = gsap.timeline();
    
    // Create a proxy object for the counter to ensure sub-pixel smoothness
    const counter = { val: 0 };

    // Animate everything together over 3 seconds
    // Power3.out starts very fast and slows down significantly at the end
    tl.to(counter, {
        val: 100,
        duration: 3,
        ease: "power2.out", 
        onUpdate: () => {
            percentText.innerText = Math.floor(counter.val);
        }
    }, 0);

    tl.to(wineWrapper, {
        height: "100%",
        duration: 1.8,
        ease: "power2.out"
    }, 0);

    // 3. THE INSTANT SPLIT (Happens at the 3s mark)
    tl.to([loaderContent, wineCurve], {
        opacity: 0,
        duration: 0.3,
        ease: "linear"
    });

    tl.set(wineWrapper, { display: "none" });

    tl.to(preloaderTop, {
        yPercent: -100,
        duration: 1.2,
        ease: "expo.inOut"
    }, "-=0.2");

    tl.to(preloaderBottom, {
        yPercent: 100,
        duration: 1.2,
        ease: "expo.inOut",
        onComplete: () => {
            preloader.style.display = "none";
            if (typeof window.init === "function") window.init();
        }
    }, "<"); 
}

            // Sparkle Cursor Logic
            const container = document.getElementById('sparkle-container');
            const colors = ["#800020", "#800020", "#800020", "#FFD700"]; 
            window.addEventListener("mousemove", (e) => {
                if(container) createSparkle(e.clientX, e.clientY);
            });

            function createSparkle(x, y) {
                const sparkle = document.createElement("div");
                const size = Math.random() * 8 + 8; 
                const color = colors[Math.floor(Math.random() * colors.length)];
                Object.assign(sparkle.style, {
                    position: "absolute",
                    left: `${x}px`,
                    top: `${y}px`,
                    width: `${size}px`,
                    height: `${size}px`,
                    backgroundColor: color,
                    clipPath: "polygon(50% 0%, 61% 39%, 100% 50%, 61% 61%, 50% 100%, 39% 61%, 0% 50%, 39% 39%)",
                    pointerEvents: "none",
                    zIndex: "9999"
                });
                container.appendChild(sparkle);
                gsap.to(sparkle, {
                    duration: 0.8,
                    x: (Math.random() - 0.5) * 100, 
                    y: (Math.random() - 0.5) * 100,
                    scale: 0,
                    opacity: 0,
                    ease: "power1.out",
                    onComplete: () => sparkle.remove()
                });
            }

            document.addEventListener("DOMContentLoaded", initLoader);
        </script>

        <script>
            import Lenis from 'lenis'
            import { gsap } from 'gsap'
            import { ScrollTrigger } from 'gsap/ScrollTrigger'
            const lenis = new Lenis({ duration: 1.2, smoothWheel: true })
            lenis.on('scroll', ScrollTrigger.update)
            gsap.ticker.add((time) => { lenis.raf(time * 1000) })
        </script>

        <style is:global>
            html.lenis, html.lenis body { height: auto; }
            .lenis.lenis-smooth { scroll-behavior: auto !important; }
        </style>
    </body>
</html>