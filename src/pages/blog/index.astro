---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";
import Articles from "@components/blog/Articles.astro";

// 1. Fetch posts from WordPress
const response = await fetch("http://127.0.0.1/glintajans/graphql/", {
  method: "POST",
  headers: { 
    "Content-Type": "application/json",
    "Host": "glint.tr" // <--- CRITICAL: Apache needs this to find the right site
  },
  body: JSON.stringify({
    query: `
      query loadAllPosts {
        posts {
          nodes {
            slug
            title
            date
            excerpt
            featuredImage {
              node {
                sourceUrl(size: LARGE) # This ensures a higher-quality image
                altText
              }
            }
            author {
              node {
                name
              }
            }
          }
        }
      }
    `,
  }),
}).catch(err => {
  console.error("FETCH ERROR:", err);
  return null;
});

const json = response ? await response.json() : null;
const posts = json?.data?.posts?.nodes || [];

// THIS WILL PRINT IN YOUR TERMINAL
console.log("Total posts found:", posts.length); 


const seo: AstroSeoProps = {
    title: "Glint Agency Blog: Insights and Updates",
    description: "Explore the Glint Agency Blog for the latest trends in web design and SEO.",
    canonical: "https://glint.tr/blog/", // Updated domain
};
---

<BaseLayout seo={seo}>
    <Articles posts={posts} />
</BaseLayout>