---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";
import Articles from "@components/blog/Articles.astro";

// 1. Fetch posts from WordPress
const response = await fetch("http://localhost/glintajans/graphql", {
  method: "POST",
  headers: { "Content-Type": "application/json" },
  body: JSON.stringify({
    query: `
      query loadAllPosts {
        posts {
          nodes {
            slug
            title
            date
            excerpt
            featuredImage {
              node {
                mediaItemUrl
                altText
              }
            }
            author {
              node {
                name
              }
            }
          }
        }
      }
    `,
  }),
}).catch(err => {
  console.error("FETCH ERROR:", err);
  return null;
});

const json = response ? await response.json() : null;
const posts = json?.data?.posts?.nodes || [];

// THIS WILL PRINT IN YOUR TERMINAL
console.log("Total posts found:", posts.length); 


const seo: AstroSeoProps = {
    title: "Majestico Studio Blog: Insights and Updates",
    description: "Explore the Majestico Studio Blog for the latest trends in web design and SEO.",
    canonical: "https://mintaka.co/blog/",
    // ... rest of your SEO object remains the same
};
---

<BaseLayout seo={seo}>
    <Articles posts={posts} />
</BaseLayout>