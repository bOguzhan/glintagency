---
import type { AstroSeoProps } from "@astrolib/seo";
import MarkdownPostLayout from "../../layouts/MarkdownPostLayout.astro";

const { slug } = Astro.params;

// Fallback to local IP if .env isn't set
const WP_GRAPHQL_URL = import.meta.env.WORDPRESS_API_URL || "http://127.0.0.1/glintajans/graphql";

const response = await fetch(WP_GRAPHQL_URL, {
  method: 'POST',
  headers: { 
    'Content-Type': 'application/json',
    'Host': 'glint.tr', // ADD THIS LINE
    'User-Agent': 'Astro-Server-Fetch' 
  },
  body: JSON.stringify({
    query: `
      query GetPostBySlug($slug: ID!) {
        post(id: $slug, idType: SLUG) {
          title
          content
          slug
          date
          excerpt
          featuredImage {
            node {
              sourceUrl(size: LARGE) # This ensures a higher-quality image
              altText
            }
          }
        }
      }
    `,
    variables: { slug },
  }),
});

if (!response.ok) {
  const text = await response.text();
  console.error("WP Error Content:", text.slice(0, 300)); 
  throw new Error(`Wordpress returned ${response.status}`);
}

const json = await response.json();
// CHANGED: Now looking for .post instead of .work
const post = json.data?.post;

if (!post) {
  console.log(`Post not found for slug: ${slug}`);
  return Astro.redirect('/404');
}

const frontmatter = {
  title: post.title,
  description: post.excerpt?.replace(/<[^>]*>?/gm, '').slice(0, 160) || "",
  author: {
    name: "Admin",
    link: "#" 
  },
  pubDate: post.date || new Date().toISOString(),
  image: {
    // UPDATED: use sourceUrl instead of mediaItemUrl
    url: post.featuredImage?.node?.sourceUrl || "", 
    alt: post.featuredImage?.node?.altText || post.title
  }
};

const seo: AstroSeoProps = {
  title: post.title,
  canonical: `https://glint.tr/blog/${post.slug}/`, // Updated to HTTPS and domain
  // ...
};
---
<style is:global>
  /* 1. Target the standard WordPress Gallery Block */
  article .wp-block-gallery.columns-3, 
  article .wp-block-gallery {
    display: grid !important;
    grid-template-columns: repeat(1, minmax(0, 1fr)) !important;
    gap: 1rem !important;
    margin: 2rem 0 !important;
  }

  /* Desktop View: Force 3 columns */
  @media (min-width: 768px) {
    article .wp-block-gallery,
    article .blocks-gallery-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    }
  }

  /* 2. Style the individual images within the grid */
  article .wp-block-gallery figure,
  article .wp-block-image {
    margin: 0 !important;
    width: 100% !important;
  }

article img {
    width: 100% !important;
    height: auto !important; /* This allows the image to scale naturally */
    
    /* REMOVE: aspect-ratio: 1/1; */
    /* REMOVE: object-fit: contain; */
    cursor: zoom-in;
    background: transparent !important; /* Force the background to be invisible */
    border-radius: 0.75rem;
    transition: transform 0.3s ease;
  }

  /* Also clear any background from the WordPress figure wrapper */
  article .wp-block-gallery figure,
  article .wp-block-image figure {
    background: transparent !important;
    margin: 0 !important;
  }

  article img:hover {
    transform: scale(1.02);
  }
</style>
<MarkdownPostLayout frontmatter={frontmatter} seo={seo}>
  <article set:html={post.content} />
</MarkdownPostLayout>