---
import type { AstroSeoProps } from "@astrolib/seo";
import MarkdownPostLayout from "../../layouts/MarkdownPostLayout.astro";

// 1. Get the slug from the URL
const { slug } = Astro.params;

// 2. Fetch only THIS specific post from WordPress
const response = await fetch("http://localhost/glintajans/graphql", {
  method: "POST",
  headers: { "Content-Type": "application/json" },
  body: JSON.stringify({
    query: `
      query getPostBySlug($id: ID!) {
        post(id: $id, idType: SLUG) {
          slug
          title
          content
          date
          excerpt
          featuredImage {
            node {
              mediaItemUrl
              altText
            }
          }
          author {
            node {
              name
            }
          }
        }
      }
    `,
    variables: { id: slug },
  }),
});

const { data } = await response.json();
const post = data?.post;

// 3. Handle 404 if post doesn't exist
if (!post) {
  return Astro.redirect('/404');
}

// 4. Map data to your layout
const frontmatter = {
  title: post.title,
  description: post.excerpt?.replace(/<[^>]*>?/gm, '').slice(0, 160),
  author: {
    name: post.author?.node?.name || "Admin",
    link: "#" 
  },
  pubDate: post.date,
  image: {
    url: post.featuredImage?.node?.mediaItemUrl,
    alt: post.featuredImage?.node?.altText || post.title
  }
};

const seo: AstroSeoProps = {
  title: post.title,
  canonical: `https://glintajans.com/blog/${post.slug}/`,
  openGraph: {
    title: post.title,
    images: [{ url: post.featuredImage?.node?.mediaItemUrl || "" }],
  },
};
---

<MarkdownPostLayout frontmatter={frontmatter} seo={seo}>
  {/* Inject the WordPress HTML content directly */}
  <article set:html={post.content} />
</MarkdownPostLayout>