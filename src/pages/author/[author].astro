---
import { getCollection } from "astro:content";
import type { AstroSeoProps } from "@astrolib/seo";
import Author from "@components/blog/Author.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const authors = await getCollection("authors");

    return authors.map((entry) => {
        // We no longer split by "/" because the slug is flat
        return { 
            params: { author: entry.slug }, 
            props: entry 
        };
    });
}

const author = Astro.props;

const seo: AstroSeoProps = {
    title: author.data.name,
    description: author.data.description,
    // Ensure your canonical URL matches your new flat structure
    canonical: `https://mintaka.co/author/${author.slug}/`,
};
---

<BaseLayout seo={seo}>
    <Author author={author} />
</BaseLayout>