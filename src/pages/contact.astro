---
import Contact from "@/components/forms/Contact.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";

const seo: AstroSeoProps = {
	title: "Contact Glint Agency: Get in Touch for Innovative Agency Solutions",
	description:
		"Reach out to Glint Agency for expert web design and SEO services. Connect with us to discuss your project and explore cutting-edge web solutions.",
	canonical: "https://glintagency.com/contact/",
};
---

<BaseLayout seo={seo}>
	<Contact />
</BaseLayout>
