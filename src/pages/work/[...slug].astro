---
import MarkdownPostLayout from "../../layouts/MarkdownPostLayout.astro";

// 1. Get the slug from the URL
const { slug } = Astro.params;

// 2. Fetch data from WordPress GraphQL
const response = await fetch(import.meta.env.WORDPRESS_API_URL, {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({
    query: `
      query GetWork($id: ID!) {
        work(id: $id, idType: SLUG) {
          title
          content
          excerpt
        }
      }
    `,
    variables: { id: slug },
  }),
});

const json = await response.json();
const entry = json.data?.work;

// 3. Handle 404 if project doesn't exist in WP
if (!entry) {
  return Astro.redirect('/404');
}

// 4. Map WP data to your existing Layout format
const frontmatter = {
  title: entry.title,
  description: entry.excerpt?.replace(/<[^>]*>?/gm, '') || "", // Strip HTML tags for SEO
};

const seo = {
    title: `${entry.title} - Glint Ajans`,
    description: frontmatter.description,
    canonical: `${import.meta.env.SITE_URL}/work/${slug}/`,
};
---

<MarkdownPostLayout frontmatter={frontmatter} seo={seo}>
    <div set:html={entry.content} />
</MarkdownPostLayout>