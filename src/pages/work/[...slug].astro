---
import { getEntry, render } from "astro:content";
import MarkdownPostLayout from "../../layouts/MarkdownPostLayout.astro";

// 1. Get the slug from the URL (e.g., "studiovision")
const { slug } = Astro.params;

// 2. Fetch the entry by combining the 'en/' prefix with the slug
// We use 'en/' here assuming your main site is English.
const entry = await getEntry("projects", `en/${slug}`);

// 3. If not found in 'en', or just as a safety 404
if (!entry) {
    console.error(`Project not found at: projects/en/${slug}`);
    return Astro.redirect("/404");
}

// 4. Use the new Astro 5.0+ render function
const { Content } = await render(entry);

const seo = {
    title: `${entry.data.title} - Glint Ajans`,
    description: entry.data.description,
    canonical: `https://89.168.120.151/work/${slug}/`,
};
---

<MarkdownPostLayout frontmatter={entry.data} seo={seo}>
    <Content />
</MarkdownPostLayout>